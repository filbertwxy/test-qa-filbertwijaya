{
  "name": "test-qa",
  "version": "1.0.0",
  "description": "Cypress + Cucumber API checks for ReqRes (https://reqres.in/api-docs)",
  "private": true,
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "cypress run",
    "test:stub": "node scripts/run-cypress-with-stub.js cypress run",
    "cypress:open:stub": "node scripts/run-cypress-with-stub.js cypress open"
  },
  "keywords": [
    "cypress",
    "cucumber",
    "reqres",
    "api-testing"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^15.12.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step-definitions/**/*.js"
    ],
    "nonGlobalStepDefinitions": false,
    "html": {
      "enabled": false
    }
  }
}
